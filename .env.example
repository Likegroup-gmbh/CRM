# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# App Configuration  
VITE_APP_NAME="CRM Dashboard"
VITE_APP_VERSION="2.0.0"

# Dropbox API (for video uploads)
DROPBOX_REFRESH_TOKEN=your-refresh-token-here
DROPBOX_APP_KEY=your-app-key-here
DROPBOX_APP_SECRET=your-app-secret-here

# Meta Graph API (Instagram Creator Discovery, Seite /instagram)
# META_ACCESS_TOKEN: Long-Lived User Token (60 Tage!) mit instagram_basic,
#   instagram_manage_insights, pages_read_engagement, ads_read, pages_show_list.
#   Kurzlebige Explorer-Tokens vorher via fb_exchange_token tauschen.
# META_IG_USER_ID: eigene Instagram-Business-Account-ID (Caller fuer Business Discovery)
META_ACCESS_TOKEN=your-long-lived-meta-token-here
META_IG_USER_ID=17841458145051730
# Optional, Default v21.0
META_GRAPH_VERSION=v21.0
